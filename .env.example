# Schwab Developer Portal → App Key / App Secret
SCHWAB_CLIENT_ID=your_app_key_here
SCHWAB_CLIENT_SECRET=your_app_secret_here

# Must exactly match Callback URL in Schwab Developer Portal (no trailing slash)
SCHWAB_REDIRECT_URI=https://phenomenal-kitsune-4703e9.netlify.app/api/broker-oauth-callback

# Netlify sets URL automatically — used as fallback for redirect URI
# URL=https://phenomenal-kitsune-4703e9.netlify.app

# Aliases also supported:
# SCHWAB_APP_KEY=
# SCHWAB_APP_SECRET=

# OpenAI (screenshot import)
# OPENAI_API_KEY=
