# Production site (custom domain)
SITE_URL=https://trendchasers.net

# Schwab Developer Portal → App Key / App Secret
SCHWAB_CLIENT_ID=your_app_key_here
SCHWAB_CLIENT_SECRET=your_app_secret_here

# Must exactly match Callback URL in Schwab Developer Portal (no trailing slash)
SCHWAB_REDIRECT_URI=https://trendchasers.net/api/broker-oauth-callback

# Aliases also supported:
# SCHWAB_APP_KEY=
# SCHWAB_APP_SECRET=

# OpenAI (screenshot import)
# OPENAI_API_KEY=

# Firebase (optional cloud sync)
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
